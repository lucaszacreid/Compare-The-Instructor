# Stripe — get your keys from https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# Admin dashboard password
ADMIN_PASSWORD=Cti-Admin-2025

# Your deployed URL (used for Stripe redirect URLs)
NEXT_PUBLIC_BASE_URL=https://comparetheinstructor.co.uk

# Upstash Redis — persistent storage shared across all serverless functions
# Create a free database at https://console.upstash.com
# Copy "REST URL" and "REST Token" from the database dashboard
UPSTASH_REDIS_REST_URL=https://your-db.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-token-here

# Ionos SMTP for reminder emails to abandoned leads
EMAIL_HOST=smtp.ionos.co.uk
EMAIL_PORT=465
EMAIL_USER=info@comparetheinstructor.co.uk
EMAIL_PASSWORD=your-ionos-email-password
